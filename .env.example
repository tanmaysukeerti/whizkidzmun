# Copy this file to .env and fill in the values.

# DATABASE_URL: Postgres connection string used for durable committee state.
# Works with any Postgres (Supabase, Neon, RDS, or a local instance).
# Supabase example (Project Settings → Database → Connection string → URI):
#   postgresql://postgres:YOUR_PASSWORD@db.xxxxxxxx.supabase.co:5432/postgres
# Hosted providers require SSL, which is enabled automatically for non-localhost
# hosts. If DATABASE_URL is left unset the app runs with an in-memory store
# (state is lost on restart) so you can try it before wiring up a database.
DATABASE_URL="postgresql://postgres:password@localhost:5432/whizkidz_mun"

# PORT: Port the fullstack server listens on (API + web app). Defaults to 3000.
PORT="3000"
